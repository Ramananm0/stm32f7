     duty = (uint32_t)((abs_vel / MOTOR_MAX_SPEED_MMPS) * (float)max_duty);
     duty = apply_trim(id, duty);
 
@@ -214,8 +215,6 @@ void Motor_SetTestDuty(Motor_ID id, uint8_t duty_percent, uint8_t forward)
 
 void Motor_StopAll(void)
 {
