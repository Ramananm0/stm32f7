     if (!g_ready) {
         return;
     }
@@ -231,7 +230,6 @@ void Motor_StopAll(void)
 
     memset(g_current_duty, 0, sizeof(g_current_duty));
     memset(g_dir, 0, sizeof(g_dir));
-    Encoder_SendDirections(dirs);
